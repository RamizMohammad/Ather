<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.mappls.sdk.maps.MapView
        android:id="@+id/map_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Next-turn banner: top-left over the map -->
    <LinearLayout
        android:id="@+id/banner_turn"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:background="@drawable/bg_glass_card"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/panel_stats">

        <TextView
            android:id="@+id/text_instruction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="2"
            android:ellipsize="end"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@color/aether_accent"
            android:text="—" />

        <TextView
            android:id="@+id/text_step_distance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textSize="13sp"
            android:textColor="@color/on_surface_variant"
            android:text="" />
    </LinearLayout>

    <!-- Stats panel: right side -->
    <LinearLayout
        android:id="@+id/panel_stats"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:background="@drawable/bg_glass_card"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout style="@style/RouteStatColumn">
                <TextView android:id="@+id/text_speed" style="@style/RouteStatValue"
                    android:textSize="30sp" android:text="0" />
                <TextView style="@style/RouteStatLabel" android:text="KM/H" />
            </LinearLayout>

            <LinearLayout style="@style/RouteStatColumn">
                <TextView android:id="@+id/text_speed_limit" style="@style/RouteStatValue"
                    android:textSize="30sp" android:text="--" />
                <TextView style="@style/RouteStatLabel" android:text="LIMIT" />
            </LinearLayout>

            <LinearLayout style="@style/RouteStatColumn">
                <TextView android:id="@+id/text_arrival" style="@style/RouteStatValue"
                    android:textSize="30sp" android:text="—" />
                <TextView style="@style/RouteStatLabel" android:text="ARRIVAL" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/text_remaining"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="10dp"
            android:textColor="@color/on_surface_variant"
            android:text="" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/button_stop"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_glass_chip"
            android:text="@string/stop_navigation"
            android:textColor="@color/error"
            android:textStyle="bold"
            style="?android:attr/borderlessButtonStyle" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
